<UserControl x:Class="Wpf.UI.Views.Auth.RegisterView_UserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Wpf.UI.Views.Auth"
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="800"
             Background="{StaticResource BackgroundBrush}">
    <Grid>
        <!-- Border For Title -->
        <Border Background="{StaticResource PrimaryBrush}" Height="220"
                VerticalAlignment="Top">
            <StackPanel Margin="0,40,0,0">
                <TextBlock Text="Join Us"
                           Foreground="White"
                           FontSize="28" FontWeight="ExtraBold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Create Your Account To Start Managing Your Business"
                           Foreground="#CCFFFFFF"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- Border For Register -->
        <Border Style="{StaticResource CardStyle}"
                Width="420"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                Padding="35,25" CornerRadius="15"
                Margin="0,80,0,20">
            <StackPanel>
                <!-- Label For Title -->
                <TextBlock Text="Create New Account"
                           Style="{StaticResource HeaderTextStyle}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"
                           FontSize="20"/>
                <!-- Label For FullName -->
                <TextBlock Text="FullName: "
                           Style="{StaticResource BodyTextStyle}"
                           FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding FullName , UpdateSourceTrigger=PropertyChanged}"
                         Height="38"
                         VerticalContentAlignment="Center"
                         Margin="0,0,0,15"/>
                <!-- Label For Email -->
                <TextBlock Text="Email: "
                           Style="{StaticResource BodyTextStyle}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,5"/>
                <TextBox Text="{Binding Email , UpdateSourceTrigger=PropertyChanged}"
                         Height="38"
                         VerticalContentAlignment="Center"
                         Margin="0,0,0,15"/>
                <!-- Label For Password -->
                <TextBlock Text="Password: "
                           Style="{StaticResource BodyTextStyle}"
                           FontWeight="SemiBold" Margin="0,0,0,5"/>
                <PasswordBox Height="38"
                             VerticalContentAlignment="Center"
                             Margin="0,0,0,15"/>
                <!-- Label For Confirm Password -->
                <TextBlock Text="Confirm Password: "
                           Style="{StaticResource BodyTextStyle}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,5"/>
                <PasswordBox Height="38"
                             VerticalContentAlignment="Center"
                             Margin="0,0,0,25"/>
                
                <!-- Button For Create Account -->
                <Button Content="Create Account"
                        Command="{Binding RegisterCommand}"
                        Height="45" FontSize="16" FontWeight="Bold"
                        Background="{StaticResource AccentBrush}"
                        Cursor="Hand"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <TextBlock Text="You Already Have an Account?  "
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="  Login  "
                               Foreground="{StaticResource PrimaryBrush}"
                               FontWeight="Bold" Cursor="Hand"
                               TextDecorations="Underline"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
