<UserControl x:Class="Wpf.UI.Views.Auth.LoginView_UserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Wpf.UI.Views.Auth"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             Background="{StaticResource BackgroundBrush}">
    <Grid>
        <!-- Border Title -->
        <Border Background="{StaticResource PrimaryBrush}"
                Height="200" VerticalAlignment="Top">
            <!--Label For Title -->
            <TextBlock Text="Welcome Back" Foreground="White"
                       FontSize="28" FontWeight="ExtraBold"
                       HorizontalAlignment="Center"
                       Margin="0,50,0,0"/>
        </Border>
        
        <!-- Border Login -->
        <Border Style="{StaticResource CardStyle}"
                Width="400"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Padding="40,30"
                CornerRadius="15">
            <StackPanel>
                <!-- Label For title -->
                <TextBlock Text="Login"
                           Style="{StaticResource HeaderTextStyle}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"
                           FontSize="22"/>
                <!-- Label For Email -->
                <TextBlock Text="Email: "
                           Style="{StaticResource BodyTextStyle}"
                           Margin="0,0,0,8" FontWeight="SemiBold"/>
                <TextBox Text="{Binding Email , UpdateSourceTrigger=PropertyChanged}"
                         Height="40" VerticalAlignment="Center"
                         Margin="0,0,0,20"/>
                <!-- Label For Password -->
                <TextBlock Text="Passowrd: "
                           Style="{StaticResource BodyTextStyle}"
                           Margin="0,0,0,8"
                           FontWeight="SemiBold"/>
                <PasswordBox Height="40"
                             VerticalAlignment="Center"
                             Margin="0,0,0,10"/>

                <Grid Margin="0,5,0,25">
                    <CheckBox Content="Remember me"
                              Foreground="{StaticResource TextSecondaryBrush}"
                              VerticalAlignment="Center"/>
                    <TextBlock Text="Forget Your Password..?"
                               Foreground="{StaticResource PrimaryBrush}"
                               HorizontalAlignment="Right"
                               Cursor="Hand"
                               VerticalAlignment="Center" FontSize="12"/>
                </Grid>

                <Button Content="Login"
                        Command="{Binding LoginCommand}"
                        Height="45" FontSize="16" FontWeight="Bold"
                        Background="{StaticResource PrimaryBrush}"
                        Cursor="Hand"></Button>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,25,0,0">
                    <TextBlock Text="Don't Have An Account ? "
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="    Create An Account Now    "
                               Foreground="{StaticResource AccentBrush}"
                               FontWeight="Bold"
                               Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
