<Window x:Class="Wpf.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Wpf.UI"
        mc:Ignorable="d"
        Title="ShopApp" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <!-- Label Dashboard -->
            <TextBlock Text="DASHBOARD"
                       Foreground="White"
                       FontSize="22" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,30"/>
            <!-- List Box For Items -->
            <ListBox Grid.Row="1"
                     Style="{StaticResource SidebarStyle}"
                     Margin="10,0">
                <!-- ListBox Items -->
                <ListBoxItem IsSelected="True">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🏠" VerticalAlignment="Center" FontSize="18"/>
                        <TextBlock Text="Home" Style="{StaticResource MenuTextStyle}"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📊" VerticalAlignment="Center" FontSize="18"/>
                        <TextBlock Text="Reports" Style="{StaticResource MenuTextStyle}"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="👥" VerticalAlignment="Center" FontSize="18"/>
                        <TextBlock Text="Users" Style="{StaticResource MenuTextStyle}"/>
                    </StackPanel>
                </ListBoxItem>
            </ListBox>
            <!-- Label For Version -->
            <TextBlock Text="Version 1.0.0"
                       Foreground="#55FFFFFF" HorizontalAlignment="Center"
                       Margin="0,64,0,5"/>
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="White" Padding="20,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="1"/>
                </Border.Effect>
                <Grid>
                    <TextBlock Text="Home Control Panel"
                               VerticalAlignment="Center"
                               Style="{StaticResource HeaderTextStyle}"
                               FontSize="18"/>
                    <Button Content="Logout"
                            Command="{Binding LogoutCommand}"
                            HorizontalAlignment="Right"
                            Background="{StaticResource AccentBrush}"
                            Width="120" Height="35"
                            FontSize="12" FontWeight="Bold"/>
                </Grid>
            </Border>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="30">
                    <TextBlock Text="Welcome Back System Administrator"
                               Style="{StaticResource HeaderTextStyle}"
                               FontSize="24" Margin="0,0,0,20"/>
                    <UniformGrid Columns="3">
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Total Sales" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="24,500$" FontSize="20" FontWeight="Bold" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="New Orders" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="120" FontSize="20" FontWeight="Bold" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Messages" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="15" FontSize="20" FontWeight="Bold" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
